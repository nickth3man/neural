{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ES2020",
    "strict": true,
    "noEmitOnError": true,
    "outDir": "../static",
    "rootDir": ".",
    "skipLibCheck": true,
    "moduleDetection": "force",
    "isolatedModules": true
  },
  "include": ["./chat.ts"]
}
