# Gil's Arena transcript stack — environment template
# Copy to `.env` and adjust: `cp .env.example .env` (Unix) or copy manually (Windows).
# The web app loads `.env` from the repository root on startup.

# =============================================================================
# OpenRouter (chat web app — optional for generated answers)
# =============================================================================
# Required for LLM replies. Retrieval + citations work without it (use "Retrieval only" in UI).
OPENROUTER_API_KEY=

# Model id on OpenRouter (default in code: openai/gpt-4o-mini if unset).
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional headers OpenRouter may use for attribution / rankings.
OPENROUTER_HTTP_REFERER=https://github.com/local/neural
OPENROUTER_APP_TITLE=Gil Transcript Chatbot

# =============================================================================
# Transcript index (web app)
# =============================================================================
# Directory containing index.faiss, chunks.json, config.json.
# Relative paths are resolved from the current working directory (run uvicorn from repo root).
GIL_INDEX_DIR=data/transcript_index
GIL_METADATA_DIR=data/metadata
GIL_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2

# =============================================================================
# Hugging Face Hub (optional — sentence-transformers / embedding downloads)
# =============================================================================
# Improves rate limits when downloading embedding models (e.g. all-MiniLM-L6-v2).
# Not read by application code today; export for CLI tools that honor HF_TOKEN.
# HF_TOKEN=
